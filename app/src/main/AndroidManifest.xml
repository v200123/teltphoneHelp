<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 声明自定义权限：允许其他应用读取通话记录 -->
    <permission
        android:name="com.u2tzjtne.telephonehelper.permission.READ_CALL_RECORDS"
        android:label="读取通话记录"
        android:description="@string/perm_read_call_records_desc"
        android:protectionLevel="normal" />
    <!-- 声明自定义权限：允许其他应用写入通话记录 -->
    <permission
        android:name="com.u2tzjtne.telephonehelper.permission.WRITE_CALL_RECORDS"
        android:label="写入通话记录"
        android:description="@string/perm_write_call_records_desc"
        android:protectionLevel="normal" />

    <!-- 主应用自身也需要声明使用这些权限，才能访问自己的 Provider -->
    <uses-permission android:name="com.u2tzjtne.telephonehelper.permission.READ_CALL_RECORDS" />
    <uses-permission android:name="com.u2tzjtne.telephonehelper.permission.WRITE_CALL_RECORDS" />

    <uses-permission android:name="android.permission.READ_CLIPBOARD"/>
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <application
        android:name=".base.App"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <provider
            android:name=".db.CallRecordProvider"
            android:authorities="com.u2tzjtne.telephonehelper.provider"
            android:enabled="true"
            android:exported="true"
            android:readPermission="com.u2tzjtne.telephonehelper.permission.READ_CALL_RECORDS"
            android:writePermission="com.u2tzjtne.telephonehelper.permission.WRITE_CALL_RECORDS" />
        <!-- 告知 XXPermissions 当前项目已经适配了分区存储特性 -->
        <meta-data
            android:name="ScopedStorage"
            android:value="true" />
        <activity
            android:name=".ui.activity.MainActivity"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <meta-data
            android:name="design_width_in_dp"
            android:value="412" />

        <activity
            android:name=".ui.activity.CallActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".ui.activity.HistoryActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".ui.activity.CallRecordingDetailActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".ui.activity.newCallActivity" />

        <activity android:name=".ui.activity.AddCallRecordActivity" />
        <activity android:name=".ui.activity.SettingsActivity"
            android:label="设置" />
        <activity android:name=".ui.activity.RingVideoManageActivity" />
        <activity android:name=".ui.activity.RingtoneBindingManageActivity"
            android:label="彩铃号码绑定" />
        <activity android:name=".ui.activity.CustomLocationListActivity"
            android:label="自定义归属地列表" />
        <activity android:name=".ui.activity.CustomLocationManageActivity"
            android:label="自定义归属地" />
        <activity android:name=".ui.activity.NoRingtonePhoneManageActivity"
            android:label="不显示彩铃的号码" />
    </application>

</manifest>
